<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="48dp">

    <!-- Brand -->
    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BLOCK"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:fontFamily="@font/inter_semibold"
        android:gravity="center"
        android:paddingTop="60dp"
        android:paddingBottom="32dp"
        android:letterSpacing="0.15" />

    <!-- Hero Status Card -->
    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="36dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_hero_default">

        <!-- Status row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/statusDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_dot_green" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNBLOCKED"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                android:fontFamily="@font/inter_semibold"
                android:letterSpacing="0.08"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00:00"
            android:textColor="@color/text_primary"
            android:textSize="56sp"
            android:fontFamily="@font/inter_thin"
            android:letterSpacing="-0.03"
            android:layout_marginTop="16dp" />

        <!-- Hint -->
        <TextView
            android:id="@+id/tvStatusHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tap block to start a session"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular"
            android:layout_marginTop="14dp" />

    </LinearLayout>

    <!-- Stats Card (tappable → Insights) -->
    <LinearLayout
        android:id="@+id/statsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:paddingVertical="20dp"
        android:paddingHorizontal="24dp"
        android:baselineAligned="false">

        <!-- Today's focus time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTodayTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0m"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/inter_light"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="focused today"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Sessions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvSessions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/inter_light"
                android:layout_gravity="end"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sessions"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_regular"
                android:layout_gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Tag Card -->
    <LinearLayout
        android:id="@+id/tagCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:paddingVertical="18dp"
        android:paddingHorizontal="24dp">

        <!-- Tag: Unpaired -->
        <LinearLayout
            android:id="@+id/tagUnpaired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_orange" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="no block paired"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Tag: Paired -->
        <LinearLayout
            android:id="@+id/tagPaired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_green" />

            <TextView
                android:id="@+id/tvTagName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Block"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginStart="12dp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/btnEditName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="edit"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnRepair"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unpair"
                android:textColor="@color/accent_red"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Block All Apps toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="18dp"
        android:background="@drawable/bg_card">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Block all apps"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchBlockAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Groups -->
    <LinearLayout
        android:id="@+id/groupsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Modes"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/btnAddGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/text_tertiary"
                android:textSize="20sp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGroups"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- Blocked Apps -->
    <LinearLayout
        android:id="@+id/appsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Blocked Apps"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tvAppCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Blocked app icons grid -->
        <LinearLayout
            android:id="@+id/blockedAppsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp" />

        <!-- Add apps button -->
        <TextView
            android:id="@+id/btnAddApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ add apps"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
</androidx.core.widget.NestedScrollView>

<!-- Bottom Nav -->
<View
    android:layout_width="match_parent"
    android:layout_height="0.5dp"
    android:background="#1A1A1A" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingTop="12dp"
    android:paddingBottom="32dp"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_home"
            android:tint="@color/text_primary"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navInsights"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_insights"
            android:tint="@color/text_tertiary"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insights"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/inter_regular"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</LinearLayout>

</LinearLayout>
